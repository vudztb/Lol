                            firetouchinterest(HRP, targetHandle, 1)
                        end
                        local pickupTime = tick()
                        while v.Parent == Workspace and (tick() - pickupTime < 1) do
                            HRP.CFrame = targetHandle.CFrame
                            if Hum then Hum:EquipTool(v) end
                            task.wait()
                        end
                    end
                end
            end

            if not foundFruit then
                if currentTween then 
                    currentTween:Cancel() 
                    currentTween = nil
