                local function tryStore(container)
                    for _, tool in pairs(container:GetChildren()) do
                        if tool:IsA("Tool") and (string.find(tool.Name, "Fruit") or tool:GetAttribute("OriginalName")) then
                            local fName = tool:GetAttribute("OriginalName") or tool.Name
                            if not StoredAttempts[fName] then StoredAttempts[fName] = 0 end
                            
                            if StoredAttempts[fName] < 5 then
                                IsBusyStoring = true
                                UpdateStatus("Đang cất: " .. fName)
                                StoreFruit(tool)
                                StoredAttempts[fName] = StoredAttempts[fName] + 1
                                task.wait(0.1) 
                            else
                               IsBusyStoring = true
                                UpdateStatus("Không thể cất! Đang hop...")
                                ServerHop()
                                task.wait(10)
                            end
                        end
                    end
                end
                tryStore(LocalPlayer.Backpack)
                if Char then tryStore(Char) end
            end

            if Config.AutoBuyRandom then
                BuyRandomFruit()
            end

            local foundFruit = false
            local fruits = {}
            for _, v in pairs(Workspace:GetChildren()) do
                if (v:IsA("Tool") or v:IsA("Model")) and string.find(v.Name, "Fruit") then
                    if v:FindFirstChild("Handle") then
                        table.insert(fruits, v)
                    end
                end
            end

            for _, v in pairs(fruits) do
                foundFruit = true
                HopStart = nil
                
                CreateESP(v)
                UpdateStatus("Đang bay đến " .. v.Name)
                
                local targetHandle = v:FindFirstChild("Handle")
                
                if targetHandle then
                    local tween = TweenTo(targetHandle.CFrame)
                    if tween then tween.Completed:Wait() end
                    
                    if v.Parent ~= Workspace then
                        local myFruit = LocalPlayer.Backpack:FindFirstChild(v.Name) or Char:FindFirstChild(v.Name)
                        if not myFruit then
                            UpdateStatus("Trái mất! Hop...")
