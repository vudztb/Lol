local currentTween = nil
local function TweenTo(targetCFrame)
    local HRP = GetRootPart()
    if not HRP then return end
    
    local Char = GetCharacter()
    local Hum = GetHumanoid()
    if not Hum or Hum.Health <= 0 then return end

    local Distance = (HRP.Position - targetCFrame.Position).Magnitude
    local Info = TweenInfo.new(Distance / Config.Speed, Enum.EasingStyle.Linear)
    
    if currentTween then currentTween:Cancel() end

    currentTween = TweenService:Create(HRP, Info, {CFrame = targetCFrame})
    currentTween:Play()
    
    local NoclipConn
    NoclipConn = RunService.Stepped:Connect(function()
        if currentTween and currentTween.PlaybackState == Enum.PlaybackState.Playing and Char then
            for _, part in pairs(Char:GetDescendants()) do
                if part:IsA("BasePart") and part.CanCollide then
                    part.CanCollide = false
                end
            end
            if HRP then HRP.Velocity = Vector3.zero end
        else
            if NoclipConn then NoclipConn:Disconnect() end
        end
    end)
    return currentTween
end

local function InvokeCommF(arg1, arg2, arg3)
    local CommF = ReplicatedStorage.Remotes.CommF_
    if CommF then
        return CommF:InvokeServer(arg1, arg2, arg3)
    end
end

local function StoreFruit(fruitInstance)
    local fruitName = fruitInstance:GetAttribute("OriginalName") or fruitInstance.Name
    local args = { [1] = "StoreFruit", [2] = fruitName, [3] = fruitInstance }
    pcall(function() ReplicatedStorage.Remotes.CommF_:InvokeServer(unpack(args)) end)
end

local function BuyRandomFruit()
    pcall(function() InvokeCommF("Cousin", "Buy") end)
end

local function AutoChooseTeam()
    pcall(function() InvokeCommF("SetTeam", Config.Team) end)
end

local function ServerHop()
    local PlaceID = game.PlaceId
    local AllIDs = {}
    local success, result = pcall(function()
        local record = HttpService:JSONDecode(game:HttpGet("https://games.roblox.com/v1/games/" .. PlaceID .. "/servers/Public?sortOrder=Asc&limit=100"))
        for i, v in pairs(record.data) do
            if v.playing < v.maxPlayers and v.id ~= game.JobId then
                table.insert(AllIDs, v.id)
            end
        end
    end)
    
    if #AllIDs > 0 then
        TeleportService:TeleportToPlaceInstance(PlaceID, AllIDs[math.random(1, #AllIDs)], LocalPlayer)
    else
        UpdateStatus("Retrying...")
        task.wait(1)
        ServerHop()
    end
end

